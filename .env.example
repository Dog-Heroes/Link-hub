# Feature flags — set to "true" to enable tabs
NEXT_PUBLIC_ENABLE_SHOP_TAB=true
NEXT_PUBLIC_ENABLE_QUIZ_TAB=true
NEXT_PUBLIC_ENABLE_STORE_LOCATOR=false
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key

# Turso Database
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Google OAuth (for /admin)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
AUTH_SECRET=generate_with_openssl_rand_base64_32

# Comma-separated list of emails allowed to access /admin (empty = allow all)
ADMIN_ALLOWED_EMAILS=your@email.com

# Shopify API (Admin via client_credentials — used for Storefront product reads)
SHOPIFY_STORE_DOMAIN=dogheroes-production.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Shopify Admin API Token (classic Private App token with write_themes scope)
# Needed for: POST /api/admin/stores/sync → pushes store-locations.json to active theme
# Create at: Shopify Admin > Apps > Develop apps > Create app > Admin API access token
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
